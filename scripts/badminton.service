[Unit]
Description=Badminton Club Night Server
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/badminton-club-night
ExecStart=/usr/bin/node server/dist/index.js
Restart=on-failure
Environment=NODE_ENV=production
EnvironmentFile=/home/pi/badminton-club-night/.env

[Install]
WantedBy=multi-user.target
