# Server
PORT=3000
NODE_ENV=development

# Supabase (online sync — leave blank for offline-only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Claude API (AI analysis — optional, requires internet)
ANTHROPIC_API_KEY=

# Google OAuth (online mode only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session secret for JWT
SESSION_SECRET=change-me-in-production

# SQLite path (defaults to ./data/club.db)
SQLITE_PATH=./data/club.db

# Club config
MAX_COURTS=6
CLUB_NAME=My Badminton Club
